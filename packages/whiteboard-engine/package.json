{
  "name": "@whiteboard/engine",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@whiteboard/core": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "bench:node-hint": "tsup src/runtime/lifecycle/watchers/nodeHint.bench.ts --format esm --outDir .bench --clean --silent && node .bench/nodeHint.bench.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"No tests\""
  }
}
