{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@whiteboard/collab": ["../../packages/whiteboard-collab/src/index.ts"],
      "@whiteboard/editor": ["../../packages/whiteboard-editor/src/index.ts"],
      "@whiteboard/editor/*": ["../../packages/whiteboard-editor/src/*.ts"],
      "@whiteboard/react": ["../../packages/whiteboard-react/src/index.ts"],
      "@whiteboard/engine": ["../../packages/whiteboard-engine/src/index.ts"],
      "@engine-types": ["../../packages/whiteboard-engine/src/types/index.ts"],
      "@engine-types/*": ["../../packages/whiteboard-engine/src/types/*"],
      "@whiteboard/core/types": ["../../packages/whiteboard-core/src/types/index.ts"],
      "@whiteboard/core/utils": ["../../packages/whiteboard-core/src/utils/index.ts"],
      "@whiteboard/core/geometry": ["../../packages/whiteboard-core/src/geometry/index.ts"],
      "@whiteboard/core/node": ["../../packages/whiteboard-core/src/node/index.ts"],
      "@whiteboard/core/mindmap": ["../../packages/whiteboard-core/src/mindmap/index.ts"],
      "@whiteboard/core/edge": ["../../packages/whiteboard-core/src/edge/index.ts"],
      "@whiteboard/core/schema": ["../../packages/whiteboard-core/src/schema/index.ts"],
      "@whiteboard/core/kernel": ["../../packages/whiteboard-core/src/kernel/index.ts"],
      "@whiteboard/core/config": ["../../packages/whiteboard-core/src/config/index.ts"],
      "@whiteboard/core/document": ["../../packages/whiteboard-core/src/document/index.ts"],
      "@whiteboard/core/perf": ["../../packages/whiteboard-core/src/perf/index.ts"],
      "types/*": ["../../packages/whiteboard-react/src/types/*"]
    }
  },
  "include": ["src"]
}
